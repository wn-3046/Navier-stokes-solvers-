nit= 100 ;
nx= 80 ; ny= 80 ; 
dx=2/(nx-1) ; dy= 1/(ny-1);
x=linspace(0,2,nx) ; y=linspace(0,1,ny); 

p=zeros(nx,ny);

for n=1:nit
    pn=p ;
    for i=2:nx-1
        for j=2:ny-1
            p(i,j)=( dy^2*( pn(i+1,j)+pn(i-1,j) )+...
                dx^2*( pn(i,j+1)+pn(i,j-1) ) )/( 2*(dx^2+dy^2) );
        end
    end
    p(1,:)=0;
    p(nx,:)=y;
    p(:,1)=p(:,2);
    p(:,ny)=p(:,ny-1);
    
end
mesh(x',y',p')





